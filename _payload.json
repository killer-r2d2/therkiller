ops":260,"children":261},{},[262],{"type":18,"value":151},{"type":13,"tag":153,"props":264,"children":265},{},[266],{"type":13,"tag":14,"props":267,"children":268},{},[269],{"type":18,"value":160},{"type":13,"tag":14,"props":271,"children":272},{},[273,274,278,279,283],{"type":18,"value":165},{"type":13,"tag":167,"props":275,"children":276},{},[277],{"type":18,"value":171},{"type":18,"value":173},{"type":13,"tag":175,"props":280,"children":281},{},[282],{"type":18,"value":179},{"type":18,"value":181},{"type":13,"tag":14,"props":285,"children":286},{},[287],{"type":13,"tag":21,"props":288,"children":290},{"href":187,"rel":289},[25],[291],{"type":18,"value":191},{"type":13,"tag":14,"props":293,"children":294},{},[295],{"type":18,"value":196},{"type":13,"tag":198,"props":297,"children":299},{"className":298,"code":202,"language":203,"meta":5},[201],[300],{"type":13,"tag":206,"props":301,"children":302},{"__ignoreMap":5},[303],{"type":18,"value":202},{"type":13,"tag":14,"props":305,"children":306},{},[307],{"type":18,"value":214},{"title":5,"searchDepth":51,"depth":51,"links":309},[310],{"id":114,"depth":51,"text":117},"content:blog:my-first-blog-post copy.md","blog/my-first-blog-post copy.md",{"_path":314,"_dir":90,"_draft":6,"_partial":6,"_locale":5,"title":315,"description":92,"author":93,"dates":316,"image":318,"body":319,"_type":53,"_id":426,"_source":55,"_file":427,"_extension":57},"/blog/my-first-project-with-kirby","My First Project with Kirby",{"published":317},"2024-04-030","/inclousion.webp",{"type":10,"children":320,"toc":418},[321,327,341,347,352,358,365,370,376,381,413],{"type":13,"tag":100,"props":322,"children":324},{"id":323},"launching-my-first-project-with-kirby-cms-a-unique-rapid-development-experience",[325],{"type":18,"value":326},"Launching My First Project with Kirby CMS: A Unique, Rapid Development Experience",{"type":13,"tag":14,"props":328,"children":329},{},[330,332,339],{"type":18,"value":331},"I'm excited to share my latest project, ",{"type":13,"tag":21,"props":333,"children":336},{"href":334,"rel":335},"https://www.inclousion.ch/",[25],[337],{"type":18,"value":338},"Inclousion.ch",{"type":18,"value":340},", where I ventured into new territories with Kirby CMS, enhanced by the utility-first approach of Tailwind CSS and the simplicity of Alpine.js.",{"type":13,"tag":112,"props":342,"children":344},{"id":343},"introduction-to-the-project",[345],{"type":18,"value":346},"Introduction to the Project",{"type":13,"tag":14,"props":348,"children":349},{},[350],{"type":18,"value":351},"This project marked my first experience with Kirby CMS. Kirby offers a flexible, file-based CMS that eliminates the need for a database, which intrigued me from the start. I decided to pair it with Tailwind CSS for styling and Alpine.js for the minimal interactive components, aiming for a lean and efficient tech stack.",{"type":13,"tag":112,"props":353,"children":355},{"id":354},"development-experience",[356],{"type":18,"value":357},"Development Experience",{"type":13,"tag":359,"props":360,"children":362},"h3",{"id":361},"kirby-cms",[363],{"type":18,"value":364},"Kirby CMS",{"type":13,"tag":14,"props":366,"children":367},{},[368],{"type":18,"value":369},"Kirby's learning curve was steep yet rewarding. Its no-database, file-driven approach made it exceptionally straightforward to setup and deploy. The CMS's panel is intuitive, allowing me to manage content flexibly without relying on traditional database constraints.",{"type":13,"tag":112,"props":371,"children":373},{"id":372},"lessons-learned-and-conclusion",[374],{"type":18,"value":375},"Lessons Learned and Conclusion",{"type":13,"tag":14,"props":377,"children":378},{},[379],{"type":18,"value":380},"This project was an excellent first foray into using Kirby CMS. It provided a fast development cycle, thanks to the combined power of Kirby, Tailwind CSS, and Alpine.js. Each tool offered its unique strengths:",{"type":13,"tag":119,"props":382,"children":383},{},[384,393,403],{"type":13,"tag":123,"props":385,"children":386},{},[387,391],{"type":13,"tag":167,"props":388,"children":389},{},[390],{"type":18,"value":364},{"type":18,"value":392}," for its simplicity and flexibility in content management.",{"type":13,"tag":123,"props":394,"children":395},{},[396,401],{"type":13,"tag":167,"props":397,"children":398},{},[399],{"type":18,"value":400},"Tailwind CSS",{"type":18,"value":402}," for its speed and utility-first design philosophy.",{"type":13,"tag":123,"props":404,"children":405},{},[406,411],{"type":13,"tag":167,"props":407,"children":408},{},[409],{"type":18,"value":410},"Alpine.js",{"type":18,"value":412}," for its minimalist approach to adding interactivity.",{"type":13,"tag":14,"props":414,"children":415},{},[416],{"type":18,"value":417},"Overall, this project not only enhanced my skills but also added a unique piece to my portfolio. For fellow developers considering this tech stack, I highly recommend diving in; it's well worth the learning curve!",{"title":5,"searchDepth":51,"depth":51,"links":419},[420,421,425],{"id":343,"depth":51,"text":346},{"id":354,"depth":51,"text":357,"children":422},[423],{"id":361,"depth":424,"text":364},3,{"id":372,"depth":51,"text":375},"content:blog:my-first-project-with-kirby.md","blog/my-first-project-with-kirby.md",1713470513113]