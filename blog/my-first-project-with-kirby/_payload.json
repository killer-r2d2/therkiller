[{"data":1,"prerenderedAt":223},["Reactive",2],{"content-/blog/my-first-project-with-kirby":3,"content-query-CvR2m5YUVX":139},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"author":10,"dates":11,"image":13,"tags":14,"body":15,"_type":134,"_id":135,"_source":136,"_file":137,"_extension":138},"/blog/my-first-project-with-kirby","blog",false,"","My First Project with Kirby","this is a small description about me for my blog alsdfaldfs alsdfkasfd","@bruno",{"published":12},"2024-04-30T00:00:00.000Z","/inclousion.jpg","kirby cms, tailwindcss, alpinejs",{"type":16,"children":17,"toc":125},"root",[18,27,44,51,56,62,69,74,80,85,120],{"type":19,"tag":20,"props":21,"children":23},"element","h1",{"id":22},"launching-my-first-project-with-kirby-cms-a-unique-rapid-development-experience",[24],{"type":25,"value":26},"text","Launching My First Project with Kirby CMS: A Unique, Rapid Development Experience",{"type":19,"tag":28,"props":29,"children":30},"p",{},[31,33,42],{"type":25,"value":32},"I'm excited to share my latest project, ",{"type":19,"tag":34,"props":35,"children":39},"a",{"href":36,"rel":37},"https://www.inclousion.ch/",[38],"nofollow",[40],{"type":25,"value":41},"Inclousion.ch",{"type":25,"value":43},", where I ventured into new territories with Kirby CMS, enhanced by the utility-first approach of Tailwind CSS and the simplicity of Alpine.js.",{"type":19,"tag":45,"props":46,"children":48},"h2",{"id":47},"introduction-to-the-project",[49],{"type":25,"value":50},"Introduction to the Project",{"type":19,"tag":28,"props":52,"children":53},{},[54],{"type":25,"value":55},"This project marked my first experience with Kirby CMS. Kirby offers a flexible, file-based CMS that eliminates the need for a database, which intrigued me from the start. I decided to pair it with Tailwind CSS for styling and Alpine.js for the minimal interactive components, aiming for a lean and efficient tech stack.",{"type":19,"tag":45,"props":57,"children":59},{"id":58},"development-experience",[60],{"type":25,"value":61},"Development Experience",{"type":19,"tag":63,"props":64,"children":66},"h3",{"id":65},"kirby-cms",[67],{"type":25,"value":68},"Kirby CMS",{"type":19,"tag":28,"props":70,"children":71},{},[72],{"type":25,"value":73},"Kirby's learning curve was steep yet rewarding. Its no-database, file-driven approach made it exceptionally straightforward to setup and deploy. The CMS's panel is intuitive, allowing me to manage content flexibly without relying on traditional database constraints.",{"type":19,"tag":45,"props":75,"children":77},{"id":76},"lessons-learned-and-conclusion",[78],{"type":25,"value":79},"Lessons Learned and Conclusion",{"type":19,"tag":28,"props":81,"children":82},{},[83],{"type":25,"value":84},"This project was an excellent first foray into using Kirby CMS. It provided a fast development cycle, thanks to the combined power of Kirby, Tailwind CSS, and Alpine.js. Each tool offered its unique strengths:",{"type":19,"tag":86,"props":87,"children":88},"ul",{},[89,100,110],{"type":19,"tag":90,"props":91,"children":92},"li",{},[93,98],{"type":19,"tag":94,"props":95,"children":96},"strong",{},[97],{"type":25,"value":68},{"type":25,"value":99}," for its simplicity and flexibility in content management.",{"type":19,"tag":90,"props":101,"children":102},{},[103,108],{"type":19,"tag":94,"props":104,"children":105},{},[106],{"type":25,"value":107},"Tailwind CSS",{"type":25,"value":109}," for its speed and utility-first design philosophy.",{"type":19,"tag":90,"props":111,"children":112},{},[113,118],{"type":19,"tag":94,"props":114,"children":115},{},[116],{"type":25,"value":117},"Alpine.js",{"type":25,"value":119}," for its minimalist approach to adding interactivity.",{"type":19,"tag":28,"props":121,"children":122},{},[123],{"type":25,"value":124},"Overall, this project not only enhanced my skills but also added a unique piece to my portfolio. For fellow developers considering this tech stack, I highly recommend diving in; it's well worth the learning curve!",{"title":7,"searchDepth":126,"depth":126,"links":127},2,[128,129,133],{"id":47,"depth":126,"text":50},{"id":58,"depth":126,"text":61,"children":130},[131],{"id":65,"depth":132,"text":68},3,{"id":76,"depth":126,"text":79},"markdown","content:blog:my-first-project-with-kirby.md","content","blog/my-first-project-with-kirby.md","md",{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"author":10,"dates":140,"image":13,"tags":14,"body":141,"_type":134,"_id":135,"_source":136,"_file":137,"_extension":138},{"published":12},{"type":16,"children":142,"toc":216},[143,147,157,161,165,169,173,177,181,185,212],{"type":19,"tag":20,"props":144,"children":145},{"id":22},[146],{"type":25,"value":26},{"type":19,"tag":28,"props":148,"children":149},{},[150,151,156],{"type":25,"value":32},{"type":19,"tag":34,"props":152,"children":154},{"href":36,"rel":153},[38],[155],{"type":25,"value":41},{"type":25,"value":43},{"type":19,"tag":45,"props":158,"children":159},{"id":47},[160],{"type":25,"value":50},{"type":19,"tag":28,"props":162,"children":163},{},[164],{"type":25,"value":55},{"type":19,"tag":45,"props":166,"children":167},{"id":58},[168],{"type":25,"value":61},{"type":19,"tag":63,"props":170,"children":171},{"id":65},[172],{"type":25,"value":68},{"type":19,"tag":28,"props":174,"children":175},{},[176],{"type":25,"value":73},{"type":19,"tag":45,"props":178,"children":179},{"id":76},[180],{"type":25,"value":79},{"type":19,"tag":28,"props":182,"children":183},{},[184],{"type":25,"value":84},{"type":19,"tag":86,"props":186,"children":187},{},[188,196,204],{"type":19,"tag":90,"props":189,"children":190},{},[191,195],{"type":19,"tag":94,"props":192,"children":193},{},[194],{"type":25,"value":68},{"type":25,"value":99},{"type":19,"tag":90,"props":197,"children":198},{},[199,203],{"type":19,"tag":94,"props":200,"children":201},{},[202],{"type":25,"value":107},{"type":25,"value":109},{"type":19,"tag":90,"props":205,"ch